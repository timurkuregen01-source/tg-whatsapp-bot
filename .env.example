# Amiral Support Bot — ortam değişkenleri
# Bu dosyayı .env olarak kopyalayıp değerleri doldur.

# Telegram bot token (BotFather'dan)
BOT_TOKEN=123456:ABC-DEF...

# Flask oturum imzalama anahtarı — güçlü rastgele bir değer:
#   python -c "import secrets; print(secrets.token_hex(32))"
PANEL_SECRET_KEY=change-me

# Panel admin girişi
ADMIN_USERNAME=admin
# Parola HASH'i (düz metin değil!). Yeni parola üretmek için:
#   python -c "from werkzeug.security import generate_password_hash as g; print(g('yeni-sifre'))"
ADMIN_PASSWORD_HASH=change-me
